// examples/test_suite.rv - Simple test suite using the testing library

import testing;
import math;
import str from "str";
import collections;

// Test math functions
fun test_math_abs() -> void {
    testing.assert_equals(format("{}", math.abs(-5)), "5", "abs(-5) should be 5");
    testing.assert_equals(format("{}", math.abs(5)), "5", "abs(5) should be 5");
    testing.assert_equals(format("{}", math.abs(0)), "0", "abs(0) should be 0");
}

fun test_math_max_min() -> void {
    testing.assert_equals(format("{}", math.max(10, 20)), "20", "max(10, 20) should be 20");
    testing.assert_equals(format("{}", math.min(10, 20)), "10", "min(10, 20) should be 10");
    testing.assert_equals(format("{}", math.max(-5, -10)), "-5", "max(-5, -10) should be -5");
}

fun test_math_rounding() -> void {
    testing.assert_equals(format("{}", math.floor(3.7)), "3", "floor(3.7) should be 3");
    testing.assert_equals(format("{}", math.ceil(3.2)), "4", "ceil(3.2) should be 4");
    testing.assert_equals(format("{}", math.round(3.5)), "4", "round(3.5) should be 4");
}

// Test string functions
fun test_string_trim() -> void {
    let trimmed: string = str.trim("  hello  ");
    testing.assert_equals(trimmed, "hello", "trim should remove spaces");

    let empty: string = str.trim("");
    testing.assert_equals(empty, "", "trim of empty string should be empty");
}

fun test_string_starts_ends_with() -> void {
    let text: string = "hello world";

    testing.assert_true(str.starts_with(text, "hello"), "should start with 'hello'");
    testing.assert_false(str.starts_with(text, "world"), "should not start with 'world'");

    testing.assert_true(str.ends_with(text, "world"), "should end with 'world'");
    testing.assert_false(str.ends_with(text, "hello"), "should not end with 'hello'");
}

fun test_string_capitalize() -> void {
    let result: string = str.capitalize("hello");
    testing.assert_equals(result, "Hello", "capitalize should work");

    let empty: string = str.capitalize("");
    testing.assert_equals(empty, "", "capitalize of empty should be empty");
}

// Test collections
fun test_map_basic() -> void {
    let map: Map = collections.new_map();

    testing.assert_equals(format("{}", map.len()), "0", "new Map should be empty");

    map = map.set("key1", "value1");
    testing.assert_equals(format("{}", map.len()), "1", "Map should have 1 item");

    testing.assert_equals(map.get("key1"), "value1", "should get correct value");
    testing.assert_true(map.has("key1"), "should contain key");
    testing.assert_false(map.has("key2"), "should not contain non-existent key");
}

fun test_map_operations() -> void {
    let map: Map = collections.new_map();

    map = map.set("name", "John");
    map = map.set("age", "30");
    map = map.set("city", "NYC");

    testing.assert_equals(format("{}", map.len()), "3", "should have 3 items");

    map = map.remove("age");
    testing.assert_equals(format("{}", map.len()), "2", "should have 2 items after removal");
    testing.assert_false(map.has("age"), "should not contain removed key");
}

fun test_set_basic() -> void {
    let set: Set = collections.new_set();

    testing.assert_equals(format("{}", set.len()), "0", "new Set should be empty");

    set = set.add("apple");
    testing.assert_equals(format("{}", set.len()), "1", "Set should have 1 item");

    testing.assert_true(set.contains("apple"), "should contain added item");
    testing.assert_false(set.contains("banana"), "should not contain non-existent item");
}

fun test_set_duplicates() -> void {
    let set: Set = collections.new_set();

    set = set.add("apple");
    set = set.add("apple");
    set = set.add("banana");

    testing.assert_equals(format("{}", set.len()), "2", "Set should not allow duplicates");
    testing.assert_true(set.contains("apple"), "should still contain apple");
    testing.assert_true(set.contains("banana"), "should contain banana");
}

// Test utilities
fun test_random_generation() -> void {
    let str1: string = testing.generate_random_string(5);
    let str2: string = testing.generate_random_string(5);

    testing.assert_equals(format("{}", len(str1)), "5", "random string should have correct length");
    testing.assert_equals(format("{}", len(str2)), "5", "random string should have correct length");

    let int1: int = testing.generate_random_int(1, 10);
    let int2: int = testing.generate_random_int(1, 10);

    testing.assert_true(int1 >= 1 and int1 <= 10, "random int should be in range");
    testing.assert_true(int2 >= 1 and int2 <= 10, "random int should be in range");
}

// Performance test
fun test_performance() -> void {
    let result: TestResult = testing.performance_test("math_operations", 1.0);

    if (result.passed) {
        print(format("Performance test passed: {}ms", result.execution_time));
    } else {
        print(format("Performance test failed: {}", result.error_message));
    }
}

// Main test runner
fun main() -> void {
    print("Raven Standard Library Test Suite");
    print("=================================");

    let all_tests: string[] = [
        "test_math_abs",
        "test_math_max_min",
        "test_math_rounding",
        "test_string_trim",
        "test_string_starts_ends_with",
        "test_string_capitalize",
        "test_map_basic",
        "test_map_operations",
        "test_set_basic",
        "test_set_duplicates",
        "test_random_generation",
        "test_performance"
    ];

    let suite: TestSuite = testing.run_test_suite("Standard Library Tests", all_tests);

    print("\nTest Results:");
    testing.print_test_results(suite);

    let report: string = testing.generate_test_report(suite);
    print("\nDetailed Report:");
    print(report);

    if (suite.failed_tests == 0) {
        print("\nAll tests passed!");
    } else {
        print(format("\n{} tests failed", suite.failed_tests));
    }
}

main();
