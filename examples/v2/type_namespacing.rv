// Two modules both declare a type named `Item`. Type namespacing at merge keeps
// the two distinct, and the importer renames them to tell them apart.
import std/io { println }
import "./type_namespacing_a" { Item as ItemA }
import "./type_namespacing_b" { Item as ItemB }

fun main() {
    println(ItemA.new(7).show())
    println(ItemB.new("hi").show())
}
