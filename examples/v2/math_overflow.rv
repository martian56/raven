// std/math integer helpers report overflow with a panic instead of returning a
// silently wrong value. These ordinary inputs stay well within range.
import std/io { println }
import std/math { abs_int, pow_int, gcd, lcm }

fun main() {
    println(abs_int(0 - 5).to_string())
    println(pow_int(2, 10).to_string())
    println(gcd(48, 18).to_string())
    println(lcm(4, 6).to_string())
}
