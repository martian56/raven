// nth rejects a negative index without consuming the iterator. Prints:
//   None
//   10
//   20
import std/iter { nth }
import std/io { println }

fun show(value: Option<Int>) {
    println(match value {
        None -> "None",
        Some(v) -> v.to_string(),
    })
}

fun main() {
    let it = [10, 20, 30].iter()
    show(nth(it, -1))   // negative index: None, iterator untouched
    show(it.next())     // still yields the first element
    show(nth([10, 20, 30].iter(), 1))
}
