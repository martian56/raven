const LIMIT: Int = 100

fun build() -> Point {
    let p = Point {
        x: 1,
        y: 2,
    }
    let q = Point { x: 3, y: 4 }
    let xs = [1, 2, 3]
    let g = { x -> x + 1 }
    let h = fun(a: Int) -> Int = a * a
    let total = xs.map(g).filter(h).len()
    let msg = "point at ${p.x}, ${p.y}"
    let r = 0..=total
    return p
}

