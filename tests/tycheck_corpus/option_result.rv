fun head(xs: List<Int>) -> Option<Int> {
    if xs.is_empty() {
        return None
    }
    return Some(xs.get(0))
}

fun divide(a: Int, b: Int) -> Result<Int, String> {
    if b == 0 {
        return Err("division by zero")
    }
    return Ok(a / b)
}

fun read(x: Option<Int>) -> Int {
    return match x {
        None -> 0,
        Some(n) -> n,
    }
}
